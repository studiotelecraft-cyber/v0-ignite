# --- Google Sheets integration for /api/schedule-call ---
# See docs/GOOGLE_SHEETS_SETUP.md for the full setup walkthrough.

# The spreadsheet that submissions are appended to.
# This is the long ID in the sheet's URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=1u4ASVURWErzFzJZ20cZF_h1Pc4mZkrEjw8oLx4IAtlw

# Optional: tab/worksheet name. Defaults to "Sheet1" if unset.
GOOGLE_SHEET_TAB=Sheet1

# Service account email from your Google Cloud service account JSON
# (the "client_email" field). Looks like:
#   ignite-sheets@your-project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key from the same JSON ("private_key" field).
# Keep the BEGIN/END markers and use literal \n for line breaks, e.g.:
#   GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=
